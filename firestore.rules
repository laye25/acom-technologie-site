// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: services
// Fields: id, name, description, price, category, image, updated_at
//
// Collection: orders
// Fields: id, user_id, service_id, status, total_price, updated_at
//
// Collection: portfolio
// Fields: id, title, description, image, category, updated_at
//
// Collection: blog_posts
// Fields: id, title, content, category, image, updated_at
//
// Collection: settings
// Fields: id, data, updated_at
//
// Collection: messages
// Fields: id, user_id, content, created_at
//
// Collection: expenses
// Fields: id, title, amount, date, category, updated_at
//
// Collection: notifications
// Fields: id, user_id, title, message, read, created_at
//
// Collection: studio_acom_categories
// Fields: id, name, icon, color, cover_image, updated_at
//
// Collection: studio_acom_products
// Fields: id, name, category_id, user_id, cover_image, updated_at
//
// Collection: variants
// Fields: id, product_id, name, price, updated_at
//
// Collection: users
// Fields: id, email, display_name, role, updated_at
//
// Collection: merchants
// Fields: id, owner_id, name, type, plan, created_at, updated_at
//
// [And other merchant-related collections...]
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email in ['contact.acomtechnologie@gmail.com', 'contact.abdoulayendiaye@gmail.com'] ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isManager() {
      return isAuthenticated() && 
        (request.auth.token.email == 'gestionnaire.acomtechnologie@gmail.com' ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager'));
    }

    function hasAnyAdminRole() {
      return isAdmin() || isManager();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Global Safety Net (Deny all by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Public Collections (Read only for everyone, write for admin)
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /portfolio/{portfolioId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /studio_acom_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /studio_acom_products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /variants/{variantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Specific Collections
    match /users/{userId} {
      allow read: if isOwner(userId) || hasAnyAdminRole();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || hasAnyAdminRole();
    }
    
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || hasAnyAdminRole() || resource.data.partner_id == request.auth.uid || resource.data.partnerId == request.auth.uid);
      // Règle assouplie pour le test
      allow create: if isAuthenticated(); 
      allow update: if hasAnyAdminRole() || (
        isAuthenticated() && 
        (
            // Partner access: only allowed fields
             (isPartner() && (resource.data.partner_id == request.auth.uid || resource.data.partnerId == request.auth.uid) && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'supplierStatus', 'trackingNumber', 'updatedAt', 'updated_at'])) ||
             // User/Owner access
             ((resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid) &&
              request.resource.data.user_id == resource.data.user_id &&
              request.resource.data.userId == resource.data.userId &&
              // Ensure created_at cannot be modified
              (request.resource.data.created_at == resource.data.created_at || request.resource.data.createdAt == resource.data.createdAt) &&
              // Restrict allowed modification fields
              request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'status', 'paid', 'deposit_paid', 'deposit_amount', 'deposit_paid_at', 
                'balance_paid', 'balance_amount', 'balance_paid_at', 'paid_at', 
                'updated_at', 'updatedAt', 'payment_method', 'payment_id', 'payments'
              ]))
        )
      );
      allow delete: if isAdmin();
    }
    
    match /designs/{designId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || resource.data.ownerId == request.auth.uid || hasAnyAdminRole());
      allow write: if isAuthenticated() && (request.resource.data.user_id == request.auth.uid || request.resource.data.userId == request.auth.uid || request.resource.data.ownerId == request.auth.uid || isAdmin());
      
      match /blocks/{blockId} {
        // For now, allow read/write if authenticated. In a real app, check if user is collaborator or owner.
        allow read, write: if isAuthenticated();
      }
      
      match /presence/{presenceId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || hasAnyAdminRole());
      allow write: if hasAnyAdminRole();
    }
    
    match /messages/{messageId} {
      // Allow reading if the user is the sender, the client, an admin, or the partner assigned to the associated order
      allow read: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        resource.data.clientUid == request.auth.uid ||
        resource.data.senderId == request.auth.uid ||
        hasAnyAdminRole() ||
        (resource.data.orderId != null && get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.partner_id == request.auth.uid) ||
        (resource.data.orderId != null && get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.partnerId == request.auth.uid) ||
        (resource.data.orderId != null && get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.user_id == request.auth.uid) ||
        (resource.data.orderId != null && get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.userId == request.auth.uid)
      );
      allow create: if isAuthenticated() && (
        request.resource.data.user_id == request.auth.uid || 
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.clientUid == request.auth.uid ||
        request.resource.data.senderId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // Admin Only Collections
    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    function isPartner() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'printer' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'designer' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner'));
    }

    // Merchant SaaS Collections
    match /merchants/{merchantId} {
      allow read: if isAuthenticated() && (resource.data.owner_id == request.auth.uid || resource.data.ownerId == request.auth.uid || hasAnyAdminRole());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.owner_id == request.auth.uid || resource.data.ownerId == request.auth.uid || hasAnyAdminRole());
      allow delete: if isAdmin();
    }

    // Match /partners
    match /partners/{partnerId} {
      allow read: if isOwner(partnerId) || hasAnyAdminRole();
      allow write: if hasAnyAdminRole();
    }

    // Match /ratings
    // Match /partner_ratings
    match /partner_ratings/{ratingId} {
      allow read: if hasAnyAdminRole() || (isAuthenticated() && resource.data.partnerId == request.auth.uid);
      allow create: if isAuthenticated() && 
                      request.resource.data.keys().hasAll(['orderId', 'partnerId', 'score']) &&
                      (request.resource.data.keys().hasAny(['createdAt', 'created_at'])) &&
                      request.resource.data.keys().size() <= 10 && 
                      request.resource.data.score >= 1 && request.resource.data.score <= 5 &&
                      (request.resource.data.get('createdAt', request.resource.data.get('created_at', request.time)) == request.time);
      allow update, delete: if isAdmin();
    }

    match /ratings/{ratingId} {
      allow read: if hasAnyAdminRole() || (isAuthenticated() && resource.data.partner_id == request.auth.uid);
      allow create: if isAuthenticated(); // Client can rate
      allow write: if hasAnyAdminRole();
    }

    match /merchant_stats/{merchantId} {
      // Stats for a merchant - readable by owner or admin
      // merchantId here is the document ID which corresponds to the merchant.id
      allow read: if isAuthenticated() && (get(/databases/$(database)/documents/merchants/$(merchantId)).data.owner_id == request.auth.uid || get(/databases/$(database)/documents/merchants/$(merchantId)).data.ownerId == request.auth.uid || hasAnyAdminRole());
      allow write: if hasAnyAdminRole();
    }

    match /usage/{tenantId} {
      // Les utilisateurs peuvent lire leur propre consommation
      allow read: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/merchants/$(tenantId)).data.owner_id == request.auth.uid || get(/databases/$(database)/documents/merchants/$(tenantId)).data.ownerId == request.auth.uid);
      // Ecriture réservée au serveur (Admin SDK exclusivement)
      allow write: if false; 
    }

    function isMerchantOwner(mId) {
      let merchantPath = /databases/$(database)/documents/merchants/$(mId);
      return isAuthenticated() && isValidId(mId) && exists(merchantPath) && 
             (get(merchantPath).data.get('owner_id', '') == request.auth.uid || 
              get(merchantPath).data.get('ownerId', '') == request.auth.uid);
    }

    // Helper for fast ownership check
    function hasOwnership(data) {
      return isAuthenticated() && (
        data.get('owner_id', '') == request.auth.uid || 
        data.get('ownerId', '') == request.auth.uid ||
        isMerchantOwner(data.get('merchant_id', data.get('merchantId', '')))
      );
    }

    match /merchant_products/{productId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /merchant_sales/{saleId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /merchant_expenses/{expenseId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /merchant_suppliers/{supplierId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /stock_movements/{movementId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /interventions/{interventionId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /projects/{projectId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /vehicles/{vehicleId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /employees/{employeeId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /students/{studentId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /patients/{patientId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }
    
    match /appointments/{appointmentId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow write: if hasOwnership(incoming()) || hasAnyAdminRole();
    }

    match /activities/{activityId} {
      allow read: if hasOwnership(existing()) || hasAnyAdminRole();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /design_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || hasAnyAdminRole());
      allow create: if true; // Allow anyone (including guests) to submit a design request
      allow update, delete: if hasAnyAdminRole();
    }
    
    match /templates/{templateId} {
      // Anyone can read public templates
      allow read: if true;
      // Authenticated users can create templates
      allow create: if isAuthenticated();
      // Only the creator or an admin can update/delete
      allow update, delete: if isAuthenticated() && (resource.data.user_id == request.auth.uid || resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
