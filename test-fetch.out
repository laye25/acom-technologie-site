    "faqContent": {
      "arrayValue": {
        "values": [
          {
            "mapValue": {
              "fields": {
                "answer": {
                  "stringValue": "Nous sommes ouverts du lundi au samedi, de 8h30 à 18h30. Notre équipe de support en ligne est également disponible pour répondre à vos questions via le chat."
                },
                "question": {
                  "stringValue": "Quels sont vos horaires d'ouverture ?"
                },
                "category": {
                  "stringValue": "Général"
                }
              }
            }
          },
          {
            "mapValue": {
              "fields": {
                "answer": {
                  "stringValue": "Notre agence principale est située à Touba Khaira, Sénégal. Vous pouvez nous trouver facilement sur Google Maps."
                },
                "question": {
                  "stringValue": "Où se trouve votre agence ?"
                },
                "category": {
                  "stringValue": "Général"
                }
              }
            }
          },
          {
            "mapValue": {
              "fields": {
                "question": {
                  "stringValue": "Quels types de supports d'impression proposez-vous ?"
                },
                "category": {
                  "stringValue": "Impression"
                },
                "answer": {
                  "stringValue": "Nous proposons une large gamme de supports : cartes de visite, flyers, dépliants, affiches grand format, bâches, autocollants, et bien plus encore."
                }
              }
            }
          },
          {
            "mapValue": {
              "fields": {
                "category": {
                  "stringValue": "Impression"
                },
                "question": {
                  "stringValue": "Quel est le délai moyen pour une commande d'impression ?"
                },
                "answer": {
                  "stringValue": "Le délai varie selon la complexité et la quantité. En général, les petites commandes sont prêtes en 24-48h, tandis que les projets plus importants peuvent prendre 3 à 5 jours ouvrables."
                }
              }
            }
          },
          {
            "mapValue": {
              "fields": {
                "category": {
                  "stringValue": "Digital"
                },
                "question": {
                  "stringValue": "Proposez-vous la création de sites web ?"
                },
                "answer": {
                  "stringValue": "Oui, nous créons des sites vitrines, des boutiques en ligne (e-commerce) et des applications web sur mesure adaptées à vos besoins spécifiques."
                }
              }
            }
          },
          {
            "mapValue": {
              "fields": {
                "answer": {
                  "stringValue": "Absolument. Nous proposons des services de community management pour booster votre présence sur Facebook, Instagram et LinkedIn."
                },
                "question": {
                  "stringValue": "Gérez-vous les réseaux sociaux pour les entreprises ?"
                },
                "category": {
                  "stringValue": "Digital"
                }
              }
            }
          },
          {
            "mapValue": {
              "fields": {
                "category": {
                  "stringValue": "Paiement"
                },
                "question": {
                  "stringValue": "Quels sont les modes de paiement acceptés ?"
                },
                "answer": {
                  "stringValue": "Nous acceptons les paiements en espèces à l'agence, ainsi que les transferts via Orange Money, Wave et Free Money pour plus de commodité."
                }
              }
            }
          },
          {
            "mapValue": {
              "fields": {
                "category": {
                  "stringValue": "Paiement"
                },
                "question": {
                  "stringValue": "Dois-je payer la totalité à la commande ?"
                },
                "answer": {
                  "stringValue": "Pour la plupart des projets, nous demandons un acompte de 50% à la commande et le solde à la livraison ou à la fin du projet."
                }
              }
            }
          }
        ]
      }
    },
