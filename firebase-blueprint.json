      "title": "TenantUsage",
      "description": "Usage tracking for SaaS billing",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "reads": { "type": "number" },
        "writes": { "type": "number" },
        "ai_generations": { "type": "number" },
        "storage_mb": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
