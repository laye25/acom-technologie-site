    "/settings/{settingId}": { "schema": "Settings", "description": "Settings collection" },
    "/messages/{messageId}": { "schema": "Message", "description": "Messages collection" },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "Expenses collection" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "Notifications collection" },
