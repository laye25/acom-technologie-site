{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information including role and brand assets.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "url" },
        "jobTitle": { "type": "string" },
        "company": { "type": "string" },
        "website": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "user"] },
        "logoUrl": { "type": "string", "format": "url" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Design": {
      "title": "User Design",
      "description": "A design created by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "elements": { "type": "array", "items": { "type": "object" } },
        "bgColor": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "preview": { "type": "string", "description": "Base64 or URL preview" }
      },
      "required": ["name", "ownerId", "elements"]
    },
    "Template": {
      "title": "Design Template",
      "description": "A reusable design template.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "elements": { "type": "array", "items": { "type": "object" } },
        "bgColor": { "type": "string" },
        "preview": { "type": "string" },
        "isOfficial": { "type": "boolean" },
        "createdBy": { "type": "string" }
      },
      "required": ["name", "category", "elements"]
    },
    "Product": {
      "title": "Studio ACOM Product",
      "description": "A product available in Studio ACOM.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "description": { "type": "string" },
        "coverImage": { "type": "string", "format": "url" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "categoryId"]
    },
    "Variant": {
      "title": "Product Variant",
      "description": "A specific variant of a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "size": { "type": "string" },
        "color": { "type": "string" },
        "shape": { "type": "string" },
        "format": { "type": "string", "enum": ["portrait", "landscape"] },
        "finish": { "type": "string" },
        "templateId": { "type": "string" },
        "previewImage": { "type": "string", "format": "url" },
        "price": { "type": "number" },
        "minQuantity": { "type": "number" },
        "maxQuantity": { "type": "number" },
        "templateSvg": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/designs/{designId}": {
      "schema": "Design",
      "description": "User-specific designs."
    },
    "/templates/{templateId}": {
      "schema": "Template",
      "description": "Shared design templates."
    },
    "/studio_acom_products/{productId}": {
      "schema": "Product",
      "description": "Studio ACOM products."
    },
    "/studio_acom_products/{productId}/variants/{variantId}": {
      "schema": "Variant",
      "description": "Variants for a specific product."
    }
  }
}
