    "/studio_acom_products/{productId}": { "schema": "StudioProduct", "description": "Studio products collection" },
    "/variants/{variantId}": { "schema": "Variant", "description": "Product variants collection" },
    "/users/{userId}": { "schema": "User", "description": "Users collection" },
    "/merchants/{merchantId}": { "schema": "Merchant", "description": "Merchants collection" },
    "/merchant_products/{productId}": { "schema": "MerchantProduct", "description": "Merchant products collection" },
    "/merchant_sales/{saleId}": { "schema": "MerchantSale", "description": "Merchant sales collection" },
    "/merchant_expenses/{expenseId}": { "schema": "MerchantExpense", "description": "Merchant expenses collection" },
    "/merchant_suppliers/{supplierId}": { "schema": "MerchantSupplier", "description": "Merchant suppliers collection" },
    "/stock_movements/{movementId}": { "schema": "StockMovement", "description": "Stock movements collection" },
    "/interventions/{interventionId}": { "schema": "Intervention", "description": "Interventions collection" },
    "/projects/{projectId}": { "schema": "Project", "description": "Projects collection" },
    "/vehicles/{vehicleId}": { "schema": "Vehicle", "description": "Vehicles collection" },
    "/employees/{employeeId}": { "schema": "Employee", "description": "Employees collection" },
    "/students/{studentId}": { "schema": "Student", "description": "Students collection" },
    "/patients/{patientId}": { "schema": "Patient", "description": "Patients collection" },
    "/appointments/{appointmentId}": { "schema": "Appointment", "description": "Appointments collection" },
    "/designs/{designId}": { "schema": "Design", "description": "Designs collection" },
    "/designs/{designId}/blocks/{blockId}": { "schema": "DesignBlock", "description": "Blocks within a design" },
    "/designs/{designId}/presence/{presenceId}": { "schema": "Presence", "description": "Real-time presence within a design" },
    "/activities/{activityId}": { "schema": "Activity", "description": "Activities collection" },
    "/usage/{tenantId}": { "schema": "TenantUsage", "description": "Usage tracking for SaaS billing" },
    "/assets/{assetId}": { "schema": "Asset", "description": "User assets collection" },
    "/design_templates/{templateId}": { "schema": "DesignTemplate", "description": "Reusable design templates" }
  }
