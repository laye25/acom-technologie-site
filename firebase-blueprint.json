  "firestore": {
    "/services/{serviceId}": { "schema": "Service", "description": "Services collection" },
    "/orders/{orderId}": { "schema": "Order", "description": "Orders collection" },
    "/portfolio/{portfolioId}": { "schema": "PortfolioItem", "description": "Portfolio collection" },
