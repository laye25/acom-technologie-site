{
  "name": "acom-technologie-saas",
  "version": "1.0.0",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "build:desktop": "npm run build && npx electron-builder"
  },
  "build": {
    "appId": "com.acom.gestion",
    "productName": "Acom Gestion Desktop",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Acom Gestion Desktop"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "@google/genai": "*",
    "@sqlite.org/sqlite-wasm": "*",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.3.0",
    "@vis.gl/react-google-maps": "^1.1.0",
    "date-fns": "^3.3.1",
    "dexie": "^3.2.4",
    "dexie-react-hooks": "^1.1.7",
    "express": "^4.18.2",
    "fabric": "^5.3.0",
    "firebase": "^10.8.0",
    "firebase-admin": "^11.11.1",
    "framer-motion": "^11.0.5",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "imagetracerjs": "^1.2.6",
    "jspdf": "^2.5.1",
    "konva": "^9.3.1",
    "lucide-react": "^0.331.0",
    "motion": "^11.11.17",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-konva": "^18.2.10",
    "react-router-dom": "^6.22.1",
    "recharts": "^2.12.0",
    "resend": "^3.1.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "sonner": "^1.4.0",
    "stripe": "^14.16.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "use-image": "^1.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/cli": "^5.0.0",
    "@tailwindcss/vite": "*",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "fake-indexeddb": "^6.2.5",
    "tsx": "^4.23.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.3"
  }
}
