{
  "name": "acom-technologie-site",
  "author": "Acom",
  "description": "Acom Studio Desktop Application",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node server.ts",
    "build": "vite build",
    "build:desktop": "npm run build && electron-builder",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.acom.gestion",
    "productName": "Acom Gestion Desktop",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "desktop/main.cjs",
      "public/icon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Acom Gestion Desktop"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.11.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/jest": "^30.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "fabric": "^5.3.0",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "html2canvas": "^1.4.1",
    "is-thirteen": "^2.0.0",
    "jspdf": "^4.2.0",
    "konva": "^10.2.3",
    "localforage": "^1.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.36.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-konva": "^19.2.3",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "resend": "^6.9.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^20.4.1",
    "svg-parser": "^2.0.4",
    "tailwind-merge": "^3.5.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tsx": "^4.21.0",
    "use-image": "^1.1.4",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fabric": "^5.3.11",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/socket.io-client": "^1.4.36",
    "autoprefixer": "^10.4.21",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "jimp": "^1.6.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite-plugin-pwa": "^1.2.0"
  }
}